
# ─── AI ─────────────────────────────────────────────────────────
# Anthropic (required for all agent intelligence)
ANTHROPIC_API_KEY=sk-ant-

# ─── YouTube ────────────────────────────────────────────────────
# YouTube Data API v3 — for trend research (Phase 1)
# Get from: console.cloud.google.com → YouTube Data API v3
YOUTUBE_API_KEY=

# YouTube OAuth — for uploading (Phase 4)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:3000/api/youtube/auth/callback

# ─── TikTok ─────────────────────────────────────────────────────
# TikTok Content Posting API (Phase 4)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:3000/api/tiktok/auth/callback

# ─── Media Generation (Phase 2) ─────────────────────────────────
# Replicate — Flux image gen + video gen
REPLICATE_API_TOKEN=

# Google Cloud TTS
GOOGLE_TTS_API_KEY=

# Ideogram — thumbnail generation
IDEOGRAM_API_KEY=

# ─── App ────────────────────────────────────────────────────────
NEXTAUTH_SECRET=your-secret-here
DATABASE_PATH=./database/agent.db
NODE_ENV=development
